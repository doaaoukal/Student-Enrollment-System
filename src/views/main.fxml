<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.MainController">

    <!-- TOP -->
    <top>
        <VBox spacing="15">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Student Course Enrollment System"
                   style="-fx-font-size:18px; -fx-font-weight:bold;"/>

            <GridPane hgap="10" vgap="10">

                <Label text="Student ID:"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="studentIdCombo"
                          promptText="Select Student ID"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="1"/>

                <Label text="Course ID:"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="courseIdCombo"
                          promptText="Select Course ID"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>

                <Label text="Enrollment Date:"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="dateField"
                           promptText="YYYY-MM-DD"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

            </GridPane>

            <HBox spacing="10">

                <Button text="Add"
                        fx:id="addButton"
                        onAction="#addEnrollment"/>

                <Button text="Update"
                        fx:id="updateButton"
                        onAction="#updateEnrollment"/>

                <Button text="Delete"
                        fx:id="deleteButton"
                        onAction="#deleteEnrollment"/>

                <Button text="Clear"
                        fx:id="clearButton"
                        onAction="#clearData"/>

            </HBox>

        </VBox>
    </top>

    <!-- CENTER TABLE -->
    <center>

        <TableView fx:id="enrollmentTable">

            <columns>

                <TableColumn fx:id="colEnrollmentId"
                             text="ID"
                             prefWidth="100"/>

                <TableColumn fx:id="colStudentId"
                             text="Student ID"
                             prefWidth="120"/>

                <TableColumn fx:id="colCourseId"
                             text="Course ID"
                             prefWidth="120"/>

                <TableColumn fx:id="colDate"
                             text="Date"
                             prefWidth="150"/>

            </columns>

        </TableView>

    </center>

</BorderPane>